# Flask Core
SECRET_KEY=your-very-long-random-secret-key-here
ADMIN_SECRET_KEY=use-a-different-strong-admin-secret-key
FLASK_ENV=development
FLASK_CONFIG=development
PORT=5000

# Database
DATABASE_URL=postgresql://pressureproof_user:password@localhost/pressureproof

# Redis (for Celery and session caching)
REDIS_URL=redis://localhost:6379/0

# Storage behavior
# development/testing: local filesystem storage
# production: AWS S3 storage

# AWS S3 (required in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_DEFAULT_REGION=ap-south-1
S3_BUCKET_NAME=pressureproof-audio

# Razorpay (Indian payment gateway - INR only)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=PressureProof <hello@pressureproof.com>

# Web Push Notifications (VAPID keys - generate with pywebpush)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=hello@pressureproof.com

# Speech Analysis
WHISPER_MODEL_SIZE=base
